{
  "name": "turbo-template",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:service": "turbo dev --filter=service-web",
    "dev:admin": "turbo dev --filter=admin-web",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "eslint-custom": "workspace:*",
    "eslint-plugin-prettier": "^5.5.5",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.9.6"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "preserveUnused": true
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msw",
      "sharp",
      "simple-git-hooks"
    ]
  }
}
